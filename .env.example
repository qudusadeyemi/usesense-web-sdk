# Demo App Environment Variables
# Copy this file to packages/demo/.env.local for local development

# UseSense API endpoint (same URL for all environments -- env is controlled by key prefix)
NEXT_PUBLIC_API_BASE_URL=https://api.usesense.ai/functions/v1/watchtower-api/api/v1

# Your organization API key
# sk_* prefix = sandbox (targets sandbox pipeline on the backend)
# pk_* prefix = production (targets production pipeline on the backend)
NEXT_PUBLIC_API_KEY=sk_your_sandbox_key_here
