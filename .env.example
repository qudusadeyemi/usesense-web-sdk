# Demo App Environment Variables
# Copy this file to packages/demo/.env.local for local development

# UseSense backend URL -- this differs between UseSense staging and production deployments
# Staging deploy:    https://staging.api.usesense.ai/functions/v1/watchtower-api/api/v1
# Production deploy: https://api.usesense.ai/functions/v1/watchtower-api/api/v1
NEXT_PUBLIC_API_BASE_URL=https://staging.api.usesense.ai/functions/v1/watchtower-api/api/v1

# Organization API key -- controls which customer environment the verification session runs in
# sk_* = organization's sandbox (test) pipeline
# pk_* = organization's production pipeline
# Both sk_ and pk_ keys work against either the staging or production backend above
NEXT_PUBLIC_API_KEY=sk_your_key_here
