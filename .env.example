# Demo App Environment Variables
# Copy this file to packages/demo/.env.local for local development

# UseSense backend URL -- differs between UseSense staging and production deployments
# Staging deploy:    https://staging.api.usesense.ai/functions/v1/watchtower-api/api/v1
# Production deploy: https://api.usesense.ai/functions/v1/watchtower-api/api/v1
NEXT_PUBLIC_API_BASE_URL=https://staging.api.usesense.ai/functions/v1/watchtower-api/api/v1

# Supabase anonymous key for the Edge Functions gateway.
# This authenticates requests at the Supabase gateway layer (sent as Authorization: Bearer + apikey header).
# It is a public key (not a secret) tied to the Supabase project backing each deployment.
# Staging and production deployments run on different Supabase projects and therefore have different anon keys.
# If omitted, the SDK falls back to the hardcoded production anon key (which will fail against staging).
NEXT_PUBLIC_GATEWAY_KEY=eyJ...your_staging_supabase_anon_key

# Organization API key -- controls which customer pipeline the verification session runs in
# sk_* = organization's sandbox (test) pipeline
# pk_* = organization's production pipeline
# Both work against either the staging or production backend above
NEXT_PUBLIC_API_KEY=sk_your_key_here
