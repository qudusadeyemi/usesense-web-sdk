{
  "name": "@usesense/web-sdk",
  "version": "4.3.0",
  "description": "UseSense Web SDK for biometric identity verification",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "usesense",
    "verification",
    "biometric",
    "liveness",
    "identity"
  ],
  "author": "UseSense",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qudusadeyemi/usesense-web-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/qudusadeyemi/usesense-web-sdk#readme",
  "bugs": {
    "url": "https://github.com/qudusadeyemi/usesense-web-sdk/issues"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^1.0.0"
  }
}
